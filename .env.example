PORT=8000
DATABASE_URL=""
APP_ENV="development"

# GitHub OAuth App Credentials (Optional if only using PAT)
GIT_CLIENT_ID="your_github_oauth_client_id"
GIT_CLIENT_SECRET="your_github_oauth_client_secret"

# JWT Encryption Details
SECRET="your_secure_random_secret_string"
ALGORITHM="HS256"
TOKEN_EXPIRE_HOURS=8

# CORS Configuration
CORS_ORIGINS="*"
